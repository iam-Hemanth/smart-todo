# Environment Variables Example for Smart To-Do

# Turso Database Configuration (Remote Sync)
TURSO_DATABASE_URL=libsql://personal-db-hemanth4.aws-ap-south-1.turso.io
TURSO_AUTH_TOKEN=your-token-here

# Shared Secret for Single-User API Authentication (Server Only)
# Checked in backend API routes for external requests (e.g. iOS Shortcuts).
# Keep this secret safe and secure in production!
PERSONAL_API_TOKEN=your-custom-shared-secret-here

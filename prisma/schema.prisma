// Prisma schema for Smart To-Do
// This app uses localStorage for persistence (no server database needed),
// but Prisma is included for future server-side persistence features.
// Docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}
